{
  "rewrites": [
    {
      "source": "/api/push/vapid-public-key",
      "destination": "/api/push?r=vapid"
    },
    {
      "source": "/api/push/settings",
      "destination": "/api/push?r=settings"
    },
    {
      "source": "/api/push/subscribe",
      "destination": "/api/push?r=subscribe"
    },
    {
      "source": "/api/push/unsubscribe",
      "destination": "/api/push?r=unsubscribe"
    },
    {
      "source": "/api/cron/push-reminders",
      "destination": "/api/push?r=cron"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/((?!api/|assets/|icons/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
