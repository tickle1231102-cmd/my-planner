# Supabase — all three values must be from the SAME project (match Vercel production).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (Vercel env + local .env.local). Never expose to the browser.
# Must match VITE_SUPABASE_URL project ref (check JWT "ref" in dashboard).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Dashboard → Authentication → Providers → Email:
# turn OFF "Confirm email" so ID-based sign-up works without inbox verification.

# Gemini memo classification (server-only). Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional. Default: gemini-2.0-flash-lite (free tier friendly)
# GEMINI_MODEL=gemini-2.0-flash-lite

# Client-side daily Gemini call cap per account (default 50). Keyword fallback after limit.
# VITE_GEMINI_DAILY_LIMIT=50
