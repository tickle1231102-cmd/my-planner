# Supabase — all three values must be from the SAME project (match Vercel production).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth:
# 1. Supabase Dashboard → Authentication → Providers → Google: enable and add
#    the Google OAuth client ID/secret.
# 2. Google Cloud Console OAuth client authorized redirect URI:
#    https://your-project.supabase.co/auth/v1/callback
# 3. Supabase Dashboard → Authentication → URL Configuration: set the app's
#    Site URL and add local/production app origins to Redirect URLs.

# Server-only (Vercel env + local .env.local). Never expose to the browser.
# Must match VITE_SUPABASE_URL project ref (check JWT "ref" in dashboard).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Dashboard → Authentication → Providers → Email:
# turn OFF "Confirm email" so ID-based sign-up works without inbox verification.

# Gemini memo classification (server-only). Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional. Default: gemini-2.0-flash-lite (free tier friendly)
# GEMINI_MODEL=gemini-2.0-flash-lite

# Client-side daily Gemini call cap per account (default 50). Keyword fallback after limit.
# VITE_GEMINI_DAILY_LIMIT=50

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Optional. mailto: or https: contact for push service.
# VAPID_SUBJECT=mailto:you@example.com

# Direct Postgres for push tables (avoids PostgREST schema-cache issues).
# On Vercel this is usually auto-provided as POSTGRES_URL / POSTGRES_URL_NON_POOLING.
# Locally: Supabase → Project Settings → Database → Connection string (URI).
# POSTGRES_URL=postgresql://postgres:...@db.xxxx.supabase.co:5432/postgres

# Protects /api/cron/push-reminders. Required in production.
# On Vercel Hobby (free), use an external scheduler (e.g. cron-job.org) every 15 minutes:
#   URL: https://YOUR-APP.vercel.app/api/cron/push-reminders
#   Header: Authorization: Bearer <same CRON_SECRET value>
CRON_SECRET=generate-a-long-random-secret
